{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch numbered article",
      "type": "shell",
      "command": "./scripts/watch_numbered_article.py --compile-on-start",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Build numbered article once",
      "type": "shell",
      "command": "./scripts/compile_numbered_article.sh",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
